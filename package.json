{
  "name": "session-control",
  "displayName": "Session Control",
  "description": "Save and resume GitHub Copilot Chat sessions linked to git commits",
  "version": "0.1.18",
  "publisher": "darrenjmcleod",
  "icon": "media/session-control.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tempuskg/session-control"
  },
  "bugs": {
    "url": "https://github.com/tempuskg/session-control/issues"
  },
  "homepage": "https://github.com/tempuskg/session-control#readme",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "copilot",
    "chat",
    "git",
    "session",
    "resume"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "session-control.saveSession",
        "title": "Session Control: Save Current Chat Session",
        "category": "Session Control"
      },
      {
        "command": "session-control.listSessions",
        "title": "Session Control: Browse Saved Sessions",
        "category": "Session Control"
      },
      {
        "command": "session-control.deleteSession",
        "title": "Session Control: Delete Saved Session",
        "category": "Session Control"
      },
      {
        "command": "session-control.refreshSessionExplorer",
        "title": "Refresh Session Explorer",
        "category": "Session Control",
        "icon": "$(refresh)"
      },
      {
        "command": "session-control.openSessionFromExplorer",
        "title": "Open Saved Session",
        "category": "Session Control"
      },
      {
        "command": "session-control.viewSessionFile",
        "title": "Session Control: View Session",
        "category": "Session Control",
        "icon": "$(open-preview)"
      },
      {
        "command": "session-control.resumeSessionFromViewer",
        "title": "Resume This Session in Chat",
        "category": "Session Control",
        "icon": "$(debug-start)"
      },
      {
        "command": "session-control.deleteSessionFromExplorer",
        "title": "Delete Saved Session",
        "category": "Session Control",
        "icon": "$(trash)"
      },
      {
        "command": "session-control.toggleAutoSave",
        "title": "Toggle Auto-Save on Chat Response",
        "category": "Session Control"
      }
    ],
    "configuration": {
      "title": "Session Control",
      "properties": {
        "session-control.storagePath": {
          "type": "string",
          "default": ".chat",
          "description": "Folder (relative to workspace root) where chat sessions are saved.",
          "scope": "resource"
        },
        "session-control.autoSaveOnChatResponse": {
          "type": "boolean",
          "default": false,
          "description": "Automatically save the active chat session after every Copilot chat response.",
          "scope": "resource"
        },
        "session-control.includeInGitignore": {
          "type": "boolean",
          "default": false,
          "description": "Add the storage folder to .gitignore. By default sessions are tracked in source control.",
          "scope": "resource"
        },
        "session-control.resume.maxTurns": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "description": "Maximum number of turns to inject as context when resuming a saved session.",
          "scope": "resource"
        },
        "session-control.resume.overflowStrategy": {
          "type": "string",
          "enum": [
            "summarize",
            "truncate",
            "recent-only"
          ],
          "enumDescriptions": [
            "Summarize older turns into a preamble using the LLM, then include the most recent turns verbatim.",
            "Silently drop the oldest turns until within the limit.",
            "Load only the most recent N turns with a note about omitted turns."
          ],
          "default": "summarize",
          "description": "What to do when a session exceeds resume.maxTurns or resume.maxContextChars.",
          "scope": "resource"
        },
        "session-control.resume.maxContextChars": {
          "type": "number",
          "default": 80000,
          "minimum": 1000,
          "description": "Hard cap on total characters injected as context when resuming. Overflow is handled by resume.overflowStrategy.",
          "scope": "resource"
        },
        "session-control.save.maxFileSize": {
          "type": "string",
          "default": "1mb",
          "pattern": "^[0-9]+(kb|mb|KB|MB)$",
          "patternErrorMessage": "Must be a size like '500kb' or '1mb'.",
          "description": "Maximum size per saved session file. Sessions exceeding this are handled by save.overflowStrategy.",
          "scope": "resource"
        },
        "session-control.save.overflowStrategy": {
          "type": "string",
          "enum": [
            "split",
            "truncateOldest",
            "warn"
          ],
          "enumDescriptions": [
            "Split the session into multiple part files linked by metadata.",
            "Drop the oldest turns until the session fits within the size limit.",
            "Save the session as-is and show a warning notification."
          ],
          "default": "split",
          "description": "What to do when a saved session file exceeds save.maxFileSize.",
          "scope": "resource"
        },
        "session-control.save.stripToolOutput": {
          "type": "boolean",
          "default": false,
          "description": "Strip verbose tool call outputs (e.g. file contents, terminal output) from saved turns to reduce file size. Tool call names and summaries are preserved.",
          "scope": "resource"
        },
        "session-control.save.maxSavedSessions": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Maximum number of session files to keep in the storage folder. 0 means unlimited. When exceeded, the oldest sessions are handled by save.pruneAction.",
          "scope": "resource"
        },
        "session-control.save.pruneAction": {
          "type": "string",
          "enum": [
            "archive",
            "delete"
          ],
          "enumDescriptions": [
            "Move the oldest sessions to a .archive/ subfolder.",
            "Permanently delete the oldest sessions."
          ],
          "default": "archive",
          "description": "What to do with the oldest sessions when save.maxSavedSessions is exceeded.",
          "scope": "resource"
        }
      }
    },
    "chatParticipants": [
      {
        "id": "session-control.resume",
        "name": "session-control",
        "description": "Resume a saved chat session",
        "isSticky": false,
        "commands": [
          {
            "name": "resume",
            "description": "Resume a previously saved chat session by injecting it as context"
          },
          {
            "name": "list",
            "description": "List all saved chat sessions with metadata"
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "session-control",
          "title": "Session Control",
          "icon": "media/session-control.svg"
        }
      ]
    },
    "views": {
      "session-control": [
        {
          "id": "session-control.sessionExplorer",
          "name": "Saved Sessions",
          "icon": "$(history)"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "session-control.saveSession"
        },
        {
          "command": "session-control.listSessions"
        },
        {
          "command": "session-control.deleteSession"
        },
        {
          "command": "session-control.toggleAutoSave"
        }
      ],
      "view/title": [
        {
          "command": "session-control.refreshSessionExplorer",
          "when": "view == session-control.sessionExplorer",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "session-control.viewSessionFile",
          "when": "(resourceExtname == .json || resourceExtname == .jsonl) && session-control.isSessionFile",
          "group": "navigation"
        },
        {
          "command": "session-control.resumeSessionFromViewer",
          "when": "activeWebviewPanelId == 'session-control.sessionViewer'",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "session-control.openSessionFromExplorer",
          "when": "view == session-control.sessionExplorer && viewItem == session-control.session",
          "group": "inline"
        },
        {
          "command": "session-control.deleteSessionFromExplorer",
          "when": "view == session-control.sessionExplorer && viewItem == session-control.session",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:production",
    "compile": "webpack",
    "watch": "webpack --watch",
    "version:build": "node ./scripts/bump-package-version.cjs",
    "build:production": "webpack --mode production --devtool hidden-source-map",
    "package": "npm run build:production",
    "compile-tests": "tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p tsconfig.test.json --watch",
    "pretest": "npm run compile-tests && npm run compile",
    "snyk:code": "snyk code test --exclude=.vscode-test,dist,dist-test,node_modules",
    "lint": "eslint src --ext ts",
    "test": "node ./dist-test/test/runTests.js"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/marked": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.0.0",
    "mocha": "^11.7.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.29.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "marked": "^4.3.0"
  }
}
